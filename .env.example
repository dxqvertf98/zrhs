# 서버 보안
APP_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes

# 프론트가 실행되는 주소 (OAuth 성공 후 이 화면으로 돌아갑니다.)
APP_OAUTH_SUCCESS_REDIRECT_URI=http://localhost:5500/index.html
APP_CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Google Cloud Console OAuth 2.0 클라이언트 값
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao Developers 애플리케이션 값
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 실제 배포에서 이메일 인증을 사용할 때 SMTP 설정
APP_REQUIRE_EMAIL_VERIFICATION=true
APP_MAIL_FROM=no-reply@your-domain.com
APP_EMAIL_VERIFICATION_URL=https://api.your-domain.com/api/auth/verify-email
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
