# 서버 보안
APP_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes

# 프론트가 실행되는 주소 (OAuth 성공 후 이 화면으로 돌아갑니다.)
APP_OAUTH_SUCCESS_REDIRECT_URI=http://localhost:5500/index.html
APP_CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Google Cloud Console OAuth 2.0 클라이언트 값
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao Developers 애플리케이션 값
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
